# =============================================================================
# Public (exposed to the browser) — prefix required: NEXT_PUBLIC_
# Set in Vercel: Project → Settings → Environment Variables (Production / Preview / Development).
# Local copy: cp .env.example .env.local
# =============================================================================

# Canonical site URL — no trailing slash; must match Search Console + GBP website field
NEXT_PUBLIC_SITE_URL=https://www.rhodesranchlasvegas.com

# --- Google Search Console (supports GBP website + entity signals) ---
# 1) Add a URL-prefix property: exactly NEXT_PUBLIC_SITE_URL (https + www as shown).
# 2) Verify: paste HTML-tag token below, deploy, then click Verify in GSC.
# 3) Sitemaps → submit: https://www.rhodesranchlasvegas.com/sitemap.xml
# 4) In Google Business Profile, set Website to the same URL as NEXT_PUBLIC_SITE_URL.
# 5) Optional: paste your public Maps / g.page link for Directions + “View on Google Maps” (profile/pin; not the /review short link).
# 6) Optional: GBP “get reviews” g.page/.../review (or override the built-in default). “View Google reviews” / footer “Google reviews” use this; Directions / Maps use MAPS_URL above.
# 7) Optional: Google Search share link (NAP, footer, key pages). Default is the site’s “Rhodes Ranch Las Vegas” SERP share URL.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_token_from_gsc_html_tag_only
# NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_MAPS_URL=https://maps.google.com/... or https://www.google.com/maps/place/... or https://g.page/... or https://maps.app.goo.gl/...
# NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_REVIEW_URL=https://g.page/r/CYB8-3JNkbuyEBI/review
# NEXT_PUBLIC_GOOGLE_SEARCH_SHARE_URL=https://share.google/pSOTtFR1dDF1BnTGt

# --- Bing Webmaster Tools (https://www.bing.com/webmasters) ---
# 1) Add site URL: same as NEXT_PUBLIC_SITE_URL (https://www.rhodesranchlasvegas.com).
# 2) Verify ownership → HTML meta tag → copy the content value into the variable below, deploy, then click Verify in Bing.
# 3) Sitemaps → Submit: https://www.rhodesranchlasvegas.com/sitemap.xml (same URL as in robots.txt).
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your_msvalidate_content_only

# Google Analytics 4 — data stream “rhodesranchlasvegas” (stream ID 14412088623), Measurement ID G-GR8HHKX1NL.
# In GA4 → Admin → Data streams → set Stream URL to exactly: https://www.rhodesranchlasvegas.com (same as NEXT_PUBLIC_SITE_URL; no trailing junk).
# Override measurement ID only if you create a new stream:
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-GR8HHKX1NL

# JSON-LD sameAs (optional) — comma/space-separated HTTPS profile URLs for RealEstateAgent (max 8). Align with real profiles only.
# Optional override; defaults in code match GBP (LinkedIn + Facebook company pages).
# NEXT_PUBLIC_SCHEMA_SAME_AS=https://www.linkedin.com/company/rhodesranchlasvegas/,https://www.facebook.com/rhodesranchlasvegashomes

# Branding (metadata titles / Open Graph site name)
NEXT_PUBLIC_SITE_BRAND_SHORT=Rhodes Ranch Las Vegas

# Agent & brokerage (NAP / JSON-LD)
NEXT_PUBLIC_AGENT_NAME=Dr. Jan Duffy
NEXT_PUBLIC_BUSINESS_NAME=Rhodes Ranch Las Vegas | Homes by Dr. Jan Duffy
NEXT_PUBLIC_BROKERAGE_NAME=Berkshire Hathaway HomeServices Nevada Properties
NEXT_PUBLIC_LICENSE_NUMBER=S.0197614.LLC
NEXT_PUBLIC_CONTACT_EMAIL=DrDuffySells@RhodesRanchLasVegas.com
NEXT_PUBLIC_SECONDARY_CONTACT_EMAIL=ChanceSells@RhodesRanchLasVegas.com
NEXT_PUBLIC_AGENT_TITLE=Listing Agent Specialist
NEXT_PUBLIC_SECONDARY_CONTACT_NAME=Chance Fuller
NEXT_PUBLIC_SECONDARY_CONTACT_TITLE=Home Buyer Specialist

# Homepage / default SEO subline (Open Graph; override for campaigns)
NEXT_PUBLIC_SEO_SITE_TAGLINE=Rhodes Ranch Las Vegas homes — local REALTOR® expertise in 89148.

# Phone: E.164 for schema/tel, display string for UI
NEXT_PUBLIC_PHONE_E164=+17026026878
NEXT_PUBLIC_PHONE_DISPLAY=(702) 602-6878
# GBP “Chat” / SMS (optional; defaults to sms:+E164 from NEXT_PUBLIC_PHONE_E164)
# NEXT_PUBLIC_PHONE_SMS_HREF=sms:+17026026878

# Office address — must match Google Business Profile & Google Search Console property (same NAP sitewide)
NEXT_PUBLIC_ADDRESS_STREET=7272 S El Capitan Way
NEXT_PUBLIC_ADDRESS_CITY=Las Vegas
NEXT_PUBLIC_ADDRESS_STATE=NV
NEXT_PUBLIC_ADDRESS_ZIP=89148
NEXT_PUBLIC_ADDRESS_COUNTRY=US

# Geo coordinates for JSON-LD (align with Google Business Profile pin)
NEXT_PUBLIC_GEO_LATITUDE=36.05581
NEXT_PUBLIC_GEO_LONGITUDE=-115.28788

# Copy blocks — match Google Business Profile (service area + hours summary)
NEXT_PUBLIC_SERVICE_AREA=Rhodes Ranch, Spring Valley, NV, USA
NEXT_PUBLIC_HOURS_SUMMARY=Open daily 9:00 a.m.–6:00 p.m. (Las Vegas time).

# GBP “From the business” highlights (one line; shown in NAP + FAQ context). Set to empty to hide: NEXT_PUBLIC_GBP_HIGHLIGHT_ATTRIBUTES_LINE=
# NEXT_PUBLIC_GBP_HIGHLIGHT_ATTRIBUTES_LINE=Women-owned · Veteran-owned

# Google Business Profile “About your business” (visible + JSON-LD; keep in sync with GBP)
# NEXT_PUBLIC_GBP_BUSINESS_DESCRIPTION=Your full About paragraph from GBP…

# Office hours for JSON-LD (24h HH:mm) — applied to all seven days per GBP
NEXT_PUBLIC_OFFICE_WEEKDAY_OPENS=09:00
NEXT_PUBLIC_OFFICE_WEEKDAY_CLOSES=18:00

# Open house tour — Google My Maps embed (Share → Embed a map). Update when you publish a new map.
NEXT_PUBLIC_OPEN_HOUSES_MAP_EMBED_URL=https://www.google.com/maps/d/embed?mid=12gQ1w5bzxrQ41HSGCdEJWFfhMtSkBwI&ehbc=2E312F

# Optional: different My Map for /locations “Key locations” (office-only, second tour, etc.).
# If omitted, defaults in lib/env.ts to the same URL as OPEN_HOUSES.
# NEXT_PUBLIC_LOCATIONS_MAP_EMBED_URL=https://www.google.com/maps/d/embed?mid=YOUR_MAP_ID&ehbc=2E312F

# Rhodes Ranch / Spring Valley area map (/map) — optional override; default is built in lib/env.ts
# NEXT_PUBLIC_RHODES_RANCH_AREA_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Google Maps: optional full iframe src from Maps → Share → Embed (overrides auto-built URL)
# NEXT_PUBLIC_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...

# If MAP_EMBED_URL is unset, embed query is built from address fields unless you override:
# NEXT_PUBLIC_MAP_QUERY=7272 S El Capitan Way, Las Vegas, NV 89148

# Google Maps Platform — on-page directions (driving, transit, walking, bicycling) to the office
# 1) Cloud Console → APIs: enable “Maps JavaScript API” and “Directions API” for the project.
# 2) Create an API key → restrict by HTTP referrer to your site (e.g. https://www.rhodesranchlasvegas.com/*).
# 3) Where to put the key (never commit real keys — .gitignore ignores .env* except this file):
#    • Vercel: Project → Environment Variables, or Team → Shared Environment Variables. Same NEXT_PUBLIC_* name. Redeploy after add/change (baked in at build).
#    • GitHub only: use Organization secrets or Repository secrets for CI (e.g. Actions that run `next build` / `vercel build`). In the workflow, pass the secret as env NEXT_PUBLIC_GOOGLE_MAPS_API_KEY for the build step. Do not store the key in the repo.
#    • If you deploy from Git to Vercel: Vercel still reads env from the Vercel project/team; GitHub secrets are for GitHub Actions, not automatic for Vercel unless your workflow deploys with the token and injects vars.
#    Primary name: NEXT_PUBLIC_GOOGLE_MAPS_API_KEY — alias: NEXT_PUBLIC_GOOGLE_MAPS_PLATFORM_KEY
# https://console.cloud.google.com/
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# RealScout widget (office listings)
# Optional script URL — must be https://em.realscout.com/.../*.js (defaults to RealScout UMD if unset)
# NEXT_PUBLIC_REALSCOUT_SCRIPT_URL=https://em.realscout.com/widgets/realscout-web-components.umd.js
NEXT_PUBLIC_REALSCOUT_AGENT_ID=QWdlbnQtMjI1MDUw
# Alphanumeric / hyphen / underscore, max 32 chars (invalid values fall back to NEWEST)
NEXT_PUBLIC_REALSCOUT_SORT_ORDER=NEWEST
# Integer 1–48 (invalid values fall back to 12)
NEXT_PUBLIC_REALSCOUT_LISTINGS_PER_PAGE=12
# minimal = agent + sort + listings-per-page (default; most reliable). full = add filters below.
NEXT_PUBLIC_REALSCOUT_WIDGET_MODE=minimal
# Office listings filters — status/types only when REALSCOUT_WIDGET_MODE=full
# Price min/max apply in both modes (purchase-focused defaults; not rental-oriented)
NEXT_PUBLIC_REALSCOUT_LISTING_STATUS=For Sale
# Open houses hub (/open-houses) — must match your MLS/RealScout label if the grid is empty
NEXT_PUBLIC_REALSCOUT_OPEN_HOUSE_LISTING_STATUS=Open House
NEXT_PUBLIC_REALSCOUT_PROPERTY_TYPES=,SFR
NEXT_PUBLIC_REALSCOUT_PRICE_MIN=350000
NEXT_PUBLIC_REALSCOUT_PRICE_MAX=15000000

# Calendly — scheduling widget (inline on /contact, badge in layout, popup CTAs)
# Must be https://calendly.com/... or https://*.calendly.com/... — match CSP and visible CTAs
NEXT_PUBLIC_CALENDLY_EVENT_URL=https://calendly.com/drjanduffy/dr-duffy-private-15-min-conversation
# Optional floating badge (defaults align with site emerald brand)
# NEXT_PUBLIC_CALENDLY_BADGE_COLOR=#14532d
# NEXT_PUBLIC_CALENDLY_BADGE_TEXT_COLOR=#ffffff
# NEXT_PUBLIC_CALENDLY_BADGE_LABEL=Schedule with Dr. Jan Duffy

# =============================================================================
# Server-only (never prefix NEXT_PUBLIC_) — CRM, webhooks, transactional email
# =============================================================================
# CONTACT_NOTIFY_EMAIL=you@example.com
# RESEND_API_KEY=
# FUB_WEBHOOK_SECRET=
